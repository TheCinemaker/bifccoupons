# Másold át a `.env`-be (a .env gitignore-olva van) és töltsd ki a saját kulcsaiddal.
# A `netlify dev` automatikusan beolvassa.

# ===== Google Sheets (coupons.ts) =====
# A Google Sheets dokumentum ID-je (a /d/<ID>/edit részből)
SPREADSHEET_ID=

# A service account JSON TELJES tartalma EGYETLEN sorba téve, idézőjelek nélkül.
# Tipp: a JSON-ban lévő \n-eket NE töröld ki, a kód automatikusan visszaalakítja sortörésre.
# Példa: {"type":"service_account","project_id":"...","private_key":"-----BEGIN ... -----\n-----END PRIVATE KEY-----\n",...}
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ===== Banggood Affiliate API (bg.ts) =====
BANGGOOD_API_KEY=
BANGGOOD_API_SECRET=

# Banggood deep-link affiliate param (go.ts) – opcionális, redirect-hez
BANGGOOD_AFFILIATE_PARAM=

# ===== AliExpress Affiliate API (ali.ts) =====
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=

# ===== UTM tracking (go.ts) – opcionális, vannak default-ok =====
# UTM_SOURCE=kvbm
# UTM_MEDIUM=pwa
# UTM_CAMPAIGN=coupons

# ===== Snapshot scheduler (snapshot-write.ts) =====
# A deployolt site saját URL-je, hogy 15 percenként megpingelje magát
# SELF_BASE_URL=https://kinabolveddmeg.netlify.app
